#!/usr/bin/env bash
# bin/duct - Duct wrapper: auto-builds Go binary if missing, then delegates

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
BINARY="$ROOT_DIR/build/duct"

# Colors
C_RESET='\033[0m'
C_GREEN='\033[0;32m'
C_YELLOW='\033[1;33m'
C_RED='\033[0;31m'

log()   { echo -e "${C_GREEN}[duct]${C_RESET} $1"; }
warn()  { echo -e "${C_YELLOW}[duct]${C_RESET} $1"; }
error() { echo -e "${C_RED}[duct]${C_RESET} $1" >&2; }

# Check if Go binary exists and is up to date
needs_build() {
    # Binary doesn't exist
    if [ ! -f "$BINARY" ]; then
        return 0
    fi

    # Source files are newer than binary
    if find "$ROOT_DIR" -name "*.go" -newer "$BINARY" | grep -q .; then
        warn "Source files changed, rebuilding..."
        return 0
    fi

    return 1
}

# Build the Go binary
build() {
    if ! command -v go >/dev/null 2>&1; then
        error "Go is not installed. Please install Go 1.22+ or download a pre-built binary."
        error "Visit: https://go.dev/dl/"
        exit 1
    fi

    log "Building duct from source..."
    cd "$ROOT_DIR"
    mkdir -p build

    local version="stable"
    if [ -d "$ROOT_DIR/.git" ]; then
        version=$(git describe --tags --always 2>/dev/null || echo "dev")
    fi

    go build \
        -ldflags "-s -w -X main.version=$version -X main.commit=$(git rev-parse --short HEAD 2>/dev/null || echo unknown)" \
        -o "$BINARY" \
        ./cmd/duct

    log "Built: $BINARY"
}

# Main
main() {
    if needs_build; then
        build
    fi

    # Delegate to real binary
    exec "$BINARY" "$@"
}

main "$@"