#!/bin/sh
# bin/duct - Duct wrapper: auto-builds Go binary if missing, then delegates
# POSIX-compliant: works with sh, dash, ash, bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
BINARY="$ROOT_DIR/build/duct"

# Simple logging (no colors for POSIX compatibility)
log()   { echo "[duct] $1"; }
warn()  { echo "[duct] WARN: $1"; }
error() { echo "[duct] ERROR: $1" >&2; }

# Check if Go binary exists
needs_build() {
    if [ ! -f "$BINARY" ]; then
        return 0
    fi
    return 1
}

# Build the Go binary
build() {
    if ! command -v go >/dev/null 2>&1; then
        error "Go is not installed. Please install Go 1.22+ or download a pre-built binary."
        error "Visit: https://go.dev/dl/"
        exit 1
    fi

    log "Building duct from source..."
    
    # Save current dir and cd to root
    ORIGINAL_DIR="$(pwd)"
    cd "$ROOT_DIR"
    mkdir -p build

    # Get version info
    version="stable"
    if [ -d "$ROOT_DIR/.git" ]; then
        version="$(git describe --tags --always 2>/dev/null || echo "dev")"
    fi
    
    commit="$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")"

    # Build
    go build \
        -ldflags "-s -w -X main.version=$version -X main.commit=$commit" \
        -o "$BINARY" \
        ./cmd/duct

    # Go back to original dir
    cd "$ORIGINAL_DIR"

    log "Built: $BINARY"
}

# Main
if needs_build; then
    build
fi

# Delegate to real binary
exec "$BINARY" "$@"